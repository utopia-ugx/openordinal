---
const { entry, lang = "en" } = Astro.props;
const dateFmt = new Intl.DateTimeFormat(lang === "fr" ? "fr-FR" : "en-GB", {
  day: "2-digit",
  month: "long",
  year: "numeric"
}).format(entry.data.date);
const title = lang === "fr" ? entry.data.title_fr || entry.data.title : entry.data.title;
---

<header class="border-b border-rule pb-6">
  <p class="ui-meta text-[10px] uppercase tracking-[0.16em] text-dim">
    {entry.data.entry_number} · {entry.data.category}
  </p>
  <h1 class="mt-2 text-[42px] font-medium leading-tight text-ink">{title}</h1>
  <p class="ui-meta mt-3 text-[11px] text-dim">{dateFmt}</p>
</header>
