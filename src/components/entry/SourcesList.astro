---
interface SourceItem {
  label: string;
  url: string;
}

interface Props {
  items?: SourceItem[];
  label?: string;
  open?: boolean;
}

const { items = [], label = "Sources", open = false }: Props = Astro.props;
---

<details class="entry-collapsible my-8 border-t border-rule pt-4" open={open}>
  <summary class="entry-collapsible__summary ui-meta text-[11px] uppercase tracking-[0.14em] text-dim">
    {label}
  </summary>
  <div class="entry-collapsible__body">
    <ul class="mt-3 space-y-1 text-[16px]">
      {
        items.map((item) => (
          <li>
            <a href={item.url} target="_blank" rel="noreferrer">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</details>
