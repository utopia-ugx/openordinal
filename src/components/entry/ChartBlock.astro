---
const { title, subtitle = "", note = "" } = Astro.props;
---

<figure class="entry-chart my-8 border border-rule p-4">
  <figcaption>
    <p class="text-lg italic text-ink">{title}</p>
    {subtitle && <p class="ui-meta mt-1 text-[10px] uppercase tracking-[0.14em] text-dim">{subtitle}</p>}
  </figcaption>
  <div class="entry-chart__scroller mt-4">
    <div class="entry-chart__inner">
      <slot />
    </div>
  </div>
  {note && <p class="ui-meta mt-3 border-t border-rule pt-3 text-[11px] text-dim">{note}</p>}
</figure>
