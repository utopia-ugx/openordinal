---
interface BarItem {
  label: string;
  value: number;
  displayValue?: string;
  type?: "accent" | "negative" | "muted" | "default";
  dividerBefore?: boolean;
  dividerLabel?: string;
}

interface Props {
  title: string;
  source: string;
  note?: string;
  variant?: "default" | "diverging";
  bars: BarItem[];
  showAxis?: boolean;
  axisMax?: number;
  labelWidth?: number;
  plotWidth?: number;
  width?: number;
}

const {
  title,
  source,
  note = "",
  variant = "default",
  bars = [],
  showAxis = false,
  axisMax,
  labelWidth = variant === "diverging" ? 194 : 118,
  plotWidth,
  width = 390
}: Props = Astro.props;

const resolvedAxisMax = axisMax ?? Math.max(...bars.map((bar) => Math.abs(bar.value)), 1);
const rowGap = variant === "diverging" ? 22 : 19;
const labeledDividerGap = 16;
const unlabeledDividerGap = 6;
const barHeight = variant === "diverging" ? 14 : 12;
const divergingLabelGap = 72;
const zeroX = labelWidth;
const resolvedPlotWidth =
  plotWidth ?? (variant === "diverging" ? 88 : Math.max(width - labelWidth - 28, 120));
const plotEndX = variant === "diverging" ? zeroX + resolvedPlotWidth : zeroX + resolvedPlotWidth;

let cursorY = 18;

const rows: Array<
  | {
      kind: "divider";
      y: number;
      label: string;
    }
  | {
      kind: "bar";
      y: number;
      width: number;
      x: number;
      labelX: number;
      labelAnchor: "start" | "end";
      valueX: number;
      valueAnchor: "start" | "end";
      valueClass: string;
      barClass: string;
      dir: "left" | "right";
      item: BarItem;
    }
> = [];

for (const item of bars) {
  if (item.dividerBefore) {
    const hasDividerLabel = Boolean(item.dividerLabel?.trim());
    rows.push({
      kind: "divider",
      y: cursorY,
      label: item.dividerLabel ?? ""
    });
    cursorY += hasDividerLabel ? labeledDividerGap : unlabeledDividerGap;
  }

  const ratio = Math.max(0, Math.min(Math.abs(item.value) / resolvedAxisMax, 1));
  const barWidth = Math.round(resolvedPlotWidth * ratio * 10) / 10;
  const isNegative = variant === "diverging" && item.value < 0;
  const x = variant === "diverging" ? (isNegative ? zeroX - barWidth : zeroX) : zeroX;
  const rawValueX =
    variant === "diverging"
      ? isNegative
        ? x - 4
        : x + barWidth + 4
      : x + barWidth + 4;
  const valueAnchor =
    variant === "diverging"
      ? isNegative
        ? "end"
        : rawValueX > width - 4
          ? "end"
          : "start"
      : rawValueX > width - 4
        ? "end"
        : "start";
  const valueX =
    valueAnchor === "end" && !(variant === "diverging" && isNegative) ? width - 4 : rawValueX;

  let barClass = "bar-rule";
  let valueClass = "scroll-bar-chart__value scroll-bar-chart__value--default";

  if (item.type === "accent") {
    barClass = "bar-acc";
    valueClass = "scroll-bar-chart__value scroll-bar-chart__value--accent";
  } else if (item.type === "negative") {
    barClass = "bar-neg";
    valueClass = "scroll-bar-chart__value scroll-bar-chart__value--negative";
  } else if (item.type === "muted") {
    barClass = "bar-dim";
    valueClass = "scroll-bar-chart__value scroll-bar-chart__value--muted";
  }

  rows.push({
    kind: "bar",
    y: cursorY,
    width: barWidth,
    x,
    labelX: variant === "diverging" ? zeroX - divergingLabelGap : 0,
    labelAnchor: variant === "diverging" ? "end" : "start",
    valueX,
    valueAnchor,
    valueClass,
    barClass,
    dir: isNegative ? "left" : "right",
    item
  });

  cursorY += rowGap;
}

const axisY = cursorY + 8;
const svgHeight = cursorY + (showAxis ? 30 : 0);
const ariaLabel = note ? `${title}. ${source}. ${note}` : `${title}. ${source}.`;
---

<figure class="scroll-bar-chart" data-chart-variant={variant}>
  <figcaption class="scroll-bar-chart__meta">
    <p class="scroll-bar-chart__title">{title}</p>
    <p class="scroll-bar-chart__source">{source}</p>
  </figcaption>

  <svg
    viewBox={`0 0 ${width} ${svgHeight}`}
    role="img"
    aria-label={ariaLabel}
    xmlns="http://www.w3.org/2000/svg"
  >
    {variant === "diverging" && (
      <>
        <line
          x1={zeroX}
          y1="6"
          x2={zeroX}
          y2={Math.max(svgHeight - 18, 6)}
          class="scroll-bar-chart__zero-line"
        />
        <text x={zeroX} y="2" text-anchor="middle" class="scroll-bar-chart__axis-text">0%</text>
      </>
    )}

    {
      rows.map((row) => {
        if (row.kind === "divider") {
          return (
            <g>
              <line
                x1="0"
                y1={row.y}
                x2={width}
                y2={row.y}
                class="scroll-bar-chart__divider"
              />
              {row.label && (
                <text x="0" y={row.y + 12} class="scroll-bar-chart__divider-label">
                  {row.label}
                </text>
              )}
            </g>
          );
        }

        return (
          <g transform={`translate(0 ${row.y})`}>
            <text
              x={row.labelX}
              y={barHeight - 1}
              text-anchor={row.labelAnchor}
              class="scroll-bar-chart__label"
            >
              {row.item.label}
            </text>
            <rect
              x={row.x}
              y="0"
              width={row.width}
              height={barHeight}
              rx="1.5"
              class:list={["scroll-bar-chart__bar", row.barClass, "bar-anim"]}
              data-dir={row.dir}
            />
            <text
              x={row.valueX}
              y={barHeight - 1}
              text-anchor={row.valueAnchor}
              class={row.valueClass}
            >
              {row.item.displayValue ?? `${row.item.value}%`}
            </text>
          </g>
        );
      })
    }

    {
      showAxis && variant === "default" && (
        <>
          <line x1={zeroX} y1={axisY} x2={plotEndX} y2={axisY} class="scroll-bar-chart__axis" />
          <text x={zeroX} y={axisY + 11} class="scroll-bar-chart__axis-text">0%</text>
          <text x={plotEndX} y={axisY + 11} text-anchor="end" class="scroll-bar-chart__axis-text">
            {resolvedAxisMax}%
          </text>
        </>
      )
    }
  </svg>

  {note && <p class="scroll-bar-chart__note">{note}</p>}
</figure>
