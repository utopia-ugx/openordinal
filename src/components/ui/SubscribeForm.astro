---
const { lang = "en", compact = false } = Astro.props;

const listmonkBaseUrl = import.meta.env.PUBLIC_LISTMONK_BASE_URL?.replace(/\/$/, "");
const listUuid = import.meta.env.PUBLIC_LISTMONK_LIST_UUID;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const isConfigured = Boolean(listmonkBaseUrl && listUuid && turnstileSiteKey);

const subscriptionPageUrl = listmonkBaseUrl
  ? `${listmonkBaseUrl}/subscription/form`
  : "";
const instanceId = `subscribe-${lang}-${compact ? "compact" : "full"}`;

const copy =
  lang === "fr"
    ? {
        label: "Recevez de nouvelles entrees par email.",
        placeholder: "Votre email",
        button: "S'abonner",
        note: "Double opt-in. Confirmation requise par email.",
        link: "Ouvrir la page d'abonnement",
        unavailable:
          "L'abonnement email n'est pas configure dans cet environnement.",
        pending: "Envoi en cours...",
        success:
          "Si cette adresse peut recevoir des emails, cherchez le message de confirmation dans votre boite de reception.",
        error: "Une erreur s'est produite. Veuillez reessayer.",
        captchaRequired: "Veuillez completer le CAPTCHA.",
      }
    : {
        label: "Get new entries by email.",
        placeholder: "Your email",
        button: "Subscribe",
        note: "Double opt-in. Email confirmation required.",
        link: "Open the subscription page",
        unavailable:
          "Email subscription is not configured in this environment.",
        pending: "Submitting...",
        success:
          "If this address can receive mail, look for the confirmation email in your inbox.",
        error: "Something went wrong. Please try again.",
        captchaRequired: "Please complete the CAPTCHA.",
      };
---

<div data-subscribe-root={instanceId}>
  {
    isConfigured ? (
      <form
        class:list={[
          "subscribe-form border border-rule p-4",
          compact ? "max-w-sm" : "max-w-xl",
        ]}
        data-subscribe-form
        data-pending={copy.pending}
        data-success={copy.success}
        data-error={copy.error}
        data-captcha-required={copy.captchaRequired}
      >
        <p class="ui-meta text-[11px] uppercase tracking-[0.15em] text-dim">
          {copy.label}
        </p>
        <div class="mt-3 flex flex-col gap-2 sm:flex-row">
          <input
            class="ui-meta w-full border border-rule bg-paper px-3 py-2 text-[13px] text-ink outline-none"
            type="email"
            name="email"
            autocomplete="email"
            placeholder={copy.placeholder}
            required
          />
          <button
            class="ui-meta border border-rule px-4 py-2 text-[11px] uppercase tracking-[0.12em] hover:bg-ink hover:text-paper disabled:cursor-not-allowed disabled:opacity-60"
            type="submit"
          >
            {copy.button}
          </button>
        </div>
        <div class="mt-3">
          <div id={`turnstile-${instanceId}`} class="min-h-[65px]"></div>
        </div>
        <div class="mt-3 flex flex-col gap-2 text-[12px] text-dim">
          <p>{copy.note}</p>
          <p>
            <a href={subscriptionPageUrl} target="_blank" rel="noreferrer">
              {copy.link}
            </a>
          </p>
          <p
            class="min-h-[1.2rem]"
            aria-live="polite"
            aria-atomic="true"
            data-subscribe-status
          />
        </div>
      </form>
    ) : (
      <div
        class:list={[
          "subscribe-form border border-rule p-4",
          compact ? "max-w-sm" : "max-w-xl",
        ]}
      >
        <p class="ui-meta text-[11px] uppercase tracking-[0.15em] text-dim">
          {copy.label}
        </p>
        <p class="mt-3 text-[14px] text-dim">{copy.unavailable}</p>
      </div>
    )
  }
</div>

<script is:inline define:vars={{ instanceId, turnstileSiteKey }}>
  const root = document.querySelector(`[data-subscribe-root="${instanceId}"]`);

  if (root) {
    const form = root.querySelector("[data-subscribe-form]");
    const status = root.querySelector("[data-subscribe-status]");
    const button = form?.querySelector('button[type="submit"]');
    let widgetId = null;

    // Load Turnstile widget
    if (turnstileSiteKey) {
      if (window.turnstile) {
        widgetId = window.turnstile.render(`#turnstile-${instanceId}`, {
          sitekey: turnstileSiteKey,
        });
      } else {
        const script = document.createElement("script");
        script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js";
        script.async = true;
        script.defer = true;
        script.onload = () => {
          if (window.turnstile) {
            widgetId = window.turnstile.render(`#turnstile-${instanceId}`, {
              sitekey: turnstileSiteKey,
            });
          }
        };
        document.head.appendChild(script);
      }
    }

    if (form && status && button) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const email = form.querySelector('input[name="email"]')?.value;
        const token =
          widgetId !== null ? window.turnstile?.getResponse(widgetId) : null;

        if (!token) {
          status.textContent =
            form.dataset.captchaRequired || "Please complete the CAPTCHA.";
          return;
        }

        button.disabled = true;
        status.textContent = form.dataset.pending || "";

        try {
          const res = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, token }),
          });

          if (res.ok) {
            status.textContent = form.dataset.success || "";
            form.reset();
            if (widgetId !== null) {
              window.turnstile?.reset(widgetId);
            }
          } else {
            const data = await res.json().catch(() => ({}));
            status.textContent =
              data.error || form.dataset.error || "Error.";
          }
        } catch {
          status.textContent = form.dataset.error || "Error.";
        } finally {
          button.disabled = false;
        }
      });
    }
  }
</script>
