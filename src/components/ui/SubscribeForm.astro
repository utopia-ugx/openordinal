---
const { lang = "en", compact = false } = Astro.props;

const listmonkBaseUrl = import.meta.env.PUBLIC_LISTMONK_BASE_URL?.replace(/\/$/, "");
const listUuid = import.meta.env.PUBLIC_LISTMONK_LIST_UUID;

if (!listmonkBaseUrl || !listUuid) {
  throw new Error("SubscribeForm requires PUBLIC_LISTMONK_BASE_URL and PUBLIC_LISTMONK_LIST_UUID.");
}

const formAction = `${listmonkBaseUrl}/api/public/subscription`;
const subscriptionPageUrl = `${listmonkBaseUrl}/subscription/form`;
const instanceId = `subscribe-${lang}-${compact ? "compact" : "full"}`;
const frameName = `newsletter-subscribe-${instanceId}`;

const copy =
  lang === "fr"
    ? {
        label: "Recevez de nouvelles entrees par email.",
        placeholder: "Votre email",
        button: "S'abonner",
        note: "Double opt-in. Confirmation requise par email.",
        link: "Ouvrir la page d'abonnement",
        pending: "Envoi en cours...",
        success:
          "Si cette adresse peut recevoir des emails, cherchez le message de confirmation dans votre boite de reception."
      }
    : {
        label: "Get new entries by email.",
        placeholder: "Your email",
        button: "Subscribe",
        note: "Double opt-in. Email confirmation required.",
        link: "Open the subscription page",
        pending: "Submitting...",
        success:
          "If this address can receive mail, look for the confirmation email in your inbox."
      };
---

<div data-subscribe-root={instanceId}>
  <form
    class:list={[
      "subscribe-form border border-rule p-4",
      compact ? "max-w-sm" : "max-w-xl"
    ]}
    action={formAction}
    method="post"
    target={frameName}
    data-subscribe-form
    data-pending={copy.pending}
    data-success={copy.success}
  >
    <p class="ui-meta text-[11px] uppercase tracking-[0.15em] text-dim">{copy.label}</p>
    <div class="mt-3 flex flex-col gap-2 sm:flex-row">
      <input
        class="ui-meta w-full border border-rule bg-paper px-3 py-2 text-[13px] text-ink outline-none"
        type="email"
        name="email"
        autocomplete="email"
        placeholder={copy.placeholder}
        required
      />
      <input type="hidden" name="l" value={listUuid} />
      <button
        class="ui-meta border border-rule px-4 py-2 text-[11px] uppercase tracking-[0.12em] hover:bg-ink hover:text-paper disabled:cursor-not-allowed disabled:opacity-60"
        type="submit"
      >
        {copy.button}
      </button>
    </div>
    <div class="mt-3 flex flex-col gap-2 text-[12px] text-dim">
      <p>{copy.note}</p>
      <p>
        <a href={subscriptionPageUrl} target="_blank" rel="noreferrer">
          {copy.link}
        </a>
      </p>
      <p class="min-h-[1.2rem]" aria-live="polite" aria-atomic="true" data-subscribe-status></p>
    </div>
  </form>
  <iframe class="hidden" name={frameName} tabindex="-1" data-subscribe-frame></iframe>
</div>

<script is:inline define:vars={{ instanceId }}>
  const root = document.querySelector(`[data-subscribe-root="${instanceId}"]`);

  if (root) {
    const form = root.querySelector("[data-subscribe-form]");
    const frame = root.querySelector("[data-subscribe-frame]");
    const status = root.querySelector("[data-subscribe-status]");
    const button = form?.querySelector('button[type="submit"]');
    let awaitingResponse = false;

    if (form && frame && status && button instanceof HTMLButtonElement) {
      form.addEventListener("submit", () => {
        awaitingResponse = true;
        button.disabled = true;
        status.textContent = form.dataset.pending || "";
      });

      frame.addEventListener("load", () => {
        if (!awaitingResponse) {
          return;
        }

        awaitingResponse = false;
        button.disabled = false;
        form.reset();
        status.textContent = form.dataset.success || "";
      });
    }
  }
</script>
