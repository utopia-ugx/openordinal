---
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";
import DevThemeToggle from "../ui/DevThemeToggle.astro";
import "../../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "fr";
  type?: "website" | "article";
  canonical?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title = "Open Ordinal",
  description = "Structured analysis of African data.",
  lang = "en",
  type = "website",
  canonical,
  ogImage,
  structuredData
} = Astro.props;

const pathname = Astro.url.pathname;
const site = Astro.site ?? new URL("https://openordinal.org");
const canonicalUrl = canonical ?? new URL(pathname, site).toString();

const enPath = pathname.startsWith("/fr")
  ? pathname.replace(/^\/fr(?=\/|$)/, "") || "/"
  : pathname;
const frPath = pathname.startsWith("/fr") ? pathname : pathname === "/" ? "/fr" : `/fr${pathname}`;

const enUrl = new URL(enPath, site).toString();
const frUrl = new URL(frPath, site).toString();

const ldJson =
  structuredData ??
  ({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Open Ordinal",
    url: "https://openordinal.org"
  } as Record<string, unknown>);

const fullTitle = title.includes("Open Ordinal") ? title : `${title} - Open Ordinal`;
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || "https://us.i.posthog.com";
const hasPosthogConfig = Boolean(posthogKey);
const canLoadPosthog = import.meta.env.PROD && hasPosthogConfig;
const showCookieUi = import.meta.env.DEV || canLoadPosthog;
const cookieConsentCopy =
  lang === "fr"
    ? {
        title: "Cookies d'analyse",
        body: "Open Ordinal utilise des cookies PostHog pour les analyses de trafic.",
        accept: "Accepter",
        reject: "Refuser"
      }
    : {
        title: "Analytics Cookies",
        body: "Open Ordinal uses PostHog cookies for traffic analytics.",
        accept: "Accept",
        reject: "Reject"
      };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Geist+Mono:wght@300;400&display=swap"
      rel="stylesheet"
    />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="fr" href={frUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(ldJson)}></script>

    <slot name="head" />
  </head>

  <body>
    <Nav lang={lang} pathname={pathname} />
    <main class="pt-12">
      <slot />
    </main>
    <Footer lang={lang} showCookieSettings={canLoadPosthog} />
    {
      showCookieUi && (
        <div
          id="oo-cookie-banner"
          class="fixed bottom-4 left-1/2 z-[80] hidden w-[calc(100%-2rem)] max-w-[34rem] -translate-x-1/2 border border-rule bg-paper p-4 text-ink shadow-[0_12px_32px_rgba(0,0,0,0.12)]"
          role="dialog"
          aria-live="polite"
          aria-label={cookieConsentCopy.title}
        >
          <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
            <div class="min-w-0 flex-1">
              <p class="ui-meta text-[11px] uppercase tracking-[0.14em] text-dim">{cookieConsentCopy.title}</p>
              <p class="mt-2 text-[15px] leading-relaxed">{cookieConsentCopy.body}</p>
            </div>
            <div class="flex shrink-0 gap-2 sm:ml-auto sm:self-end">
              <button
                id="oo-cookie-accept"
                type="button"
                class="ui-meta border border-ink bg-ink px-3 py-2 text-[11px] uppercase tracking-[0.14em] text-paper"
              >
                {cookieConsentCopy.accept}
              </button>
              <button
                id="oo-cookie-reject"
                type="button"
                class="ui-meta border border-rule px-3 py-2 text-[11px] uppercase tracking-[0.14em] text-ink"
              >
                {cookieConsentCopy.reject}
              </button>
            </div>
          </div>
        </div>
      )
    }
    {
      showCookieUi && (
        <script is:inline define:vars={{ posthogKey, posthogHost, canLoadPosthog }}>
          (() => {
            const consentKey = "oo_cookie_consent_v1";
            let posthogLoaded = false;
            const banner = document.getElementById("oo-cookie-banner");
            const acceptBtn = document.getElementById("oo-cookie-accept");
            const rejectBtn = document.getElementById("oo-cookie-reject");
            const settingsButtons = document.querySelectorAll("[data-cookie-settings]");

            const hideBanner = () => banner?.classList.add("hidden");
            const showBanner = () => banner?.classList.remove("hidden");

            const initPosthog = () => {
              if (!canLoadPosthog) {
                return;
              }
              if (posthogLoaded || window.posthog?.__SV) {
                posthogLoaded = true;
                return;
              }

              !(function (t, e) {
                let o;
                let p;
                let r;
                if (e.__SV) {
                  return;
                }
                window.posthog = e;
                e._i = [];
                e.init = function (i, s, a) {
                  function g(target, key) {
                    const parts = key.split(".");
                    if (parts.length === 2) {
                      target = target[parts[0]];
                      key = parts[1];
                    }
                    target[key] = function () {
                      target.push([key].concat(Array.prototype.slice.call(arguments, 0)));
                    };
                  }

                  p = t.createElement("script");
                  p.type = "text/javascript";
                  p.crossOrigin = "anonymous";
                  p.async = true;
                  p.src = s.api_host.replace(".i.posthog.com", "-assets.i.posthog.com") + "/static/array.js";
                  r = t.getElementsByTagName("script")[0];
                  r.parentNode.insertBefore(p, r);

                  const posthogRef = a ? (e[a] = []) : e;
                  if (!a) {
                    a = "posthog";
                  }

                  posthogRef.people = posthogRef.people || [];
                  posthogRef.toString = function (stub) {
                    let base = "posthog";
                    if (a !== "posthog") {
                      base += "." + a;
                    }
                    if (!stub) {
                      base += " (stub)";
                    }
                    return base;
                  };
                  posthogRef.people.toString = function () {
                    return posthogRef.toString(1) + ".people (stub)";
                  };

                  const methods =
                    "init capture register register_once register_for_session unregister unregister_for_session reset people.set people.set_once people.unset people.increment people.append people.union people.track_charge people.clear_charges people.delete_user people.remove_property get_property get_distinct_id identify alias screen capture pageview reset_groups group set_config set_person_properties opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing start_batch_senders stop_batch_senders".split(
                      " "
                    );

                  for (o = 0; o < methods.length; o++) {
                    g(posthogRef, methods[o]);
                  }
                  e._i.push([i, s, a]);
                };
                e.__SV = 1;
              })(document, window.posthog || []);

              window.posthog.init(posthogKey, {
                api_host: posthogHost,
                autocapture: true,
                capture_pageview: true,
                capture_pageleave: true,
                person_profiles: "identified_only",
                disable_session_recording: true
              });
              posthogLoaded = true;
            };

            const storedConsent = localStorage.getItem(consentKey);
            if (storedConsent === "accepted") {
              hideBanner();
              initPosthog();
            } else if (storedConsent === "rejected") {
              hideBanner();
              window.posthog?.opt_out_capturing?.();
            } else {
              showBanner();
            }

            acceptBtn?.addEventListener("click", () => {
              localStorage.setItem(consentKey, "accepted");
              hideBanner();
              initPosthog();
            });

            rejectBtn?.addEventListener("click", () => {
              localStorage.setItem(consentKey, "rejected");
              hideBanner();
              window.posthog?.opt_out_capturing?.();
            });

            settingsButtons.forEach((button) => {
              button.addEventListener("click", () => {
                showBanner();
              });
            });
          })();
        </script>
      )
    }
    {import.meta.env.DEV && <DevThemeToggle />}
    <script is:inline>
      (() => {
        const langCode = (document.documentElement.lang || "en").toLowerCase();
        const copy = langCode.startsWith("fr")
          ? {
              prevalence: "Prevalence Pew",
              subregion: "Sous-region",
              legal: "Statut juridique",
              sexRatio: "Ratio hommes-femmes a 30 ans",
              duality: "Dualite juridique",
              shareOfBirths: "Part des naissances africaines en 2026",
              births2026: "Naissances en 2026",
              value: "Valeur",
              yes: "oui",
              no: "non"
            }
          : {
              prevalence: "Pew prevalence",
              subregion: "Subregion",
              legal: "Legal status",
              sexRatio: "Sex ratio at age 30",
              duality: "Legal duality",
              shareOfBirths: "Share of Africa births in 2026",
              births2026: "Births in 2026",
              value: "Value",
              yes: "yes",
              no: "no"
            };

        const parseNumber = (value) => {
          const parsed = Number.parseFloat(value ?? "");
          return Number.isFinite(parsed) ? parsed : null;
        };

        const clamp = (value, min, max) => Math.max(min, Math.min(value, max));
        const cleanText = (value) => (value || "").replace(/\s+/g, " ").trim();

        const getSvgWidth = (svg) => {
          const viewBoxParts = (svg.getAttribute("viewBox") || "")
            .split(/\s+/)
            .map((part) => Number.parseFloat(part));
          if (viewBoxParts.length === 4 && Number.isFinite(viewBoxParts[2])) {
            return viewBoxParts[2];
          }
          const attrWidth = parseNumber(svg.getAttribute("width"));
          if (attrWidth) {
            return attrWidth;
          }
          return svg.getBoundingClientRect().width || 1000;
        };

        const discoverBarTargets = (svg) => {
          const svgWidth = getSvgWidth(svg);
          const texts = Array.from(svg.querySelectorAll("text")).map((node) => ({
            node,
            text: cleanText(node.textContent),
            x: parseNumber(node.getAttribute("x")),
            y: parseNumber(node.getAttribute("y")),
            anchor: (node.getAttribute("text-anchor") || "start").toLowerCase()
          }));

          return Array.from(svg.querySelectorAll("rect"))
            .map((rect) => {
              const x = parseNumber(rect.getAttribute("x"));
              const y = parseNumber(rect.getAttribute("y"));
              const width = parseNumber(rect.getAttribute("width"));
              const height = parseNumber(rect.getAttribute("height"));
              if (x === null || y === null || width === null || height === null) {
                return null;
              }
              if (height < 16 || height > 40) {
                return null;
              }
              if (width <= 8 || width >= svgWidth * 0.92) {
                return null;
              }
              const fill = (rect.getAttribute("fill") || "").toLowerCase();
              if (!fill || fill.includes("var(--paper)") || fill.includes("transparent")) {
                return null;
              }

              const centerY = y + height / 2;
              const rowTexts = texts.filter(
                (item) => item.text && item.y !== null && Math.abs(item.y - centerY) <= 8
              );
              if (!rowTexts.length) {
                return null;
              }

              const label = rowTexts
                .filter(
                  (item) =>
                    item.x !== null &&
                    item.x <= x + 2 &&
                    (item.anchor === "end" || item.x < x - 6)
                )
                .sort((a, b) => (b.x ?? 0) - (a.x ?? 0))[0];

              if (!label) {
                return null;
              }

              const value =
                rowTexts
                  .filter((item) => item !== label && item.x !== null && item.x >= x + width - 4)
                  .sort((a, b) => (a.x ?? 0) - (b.x ?? 0))[0] ||
                rowTexts
                  .filter((item) => item !== label && item.x !== null)
                  .sort(
                    (a, b) =>
                      Math.abs((a.x ?? 0) - (x + width)) - Math.abs((b.x ?? 0) - (x + width))
                  )[0];

              const labelText = cleanText(label.text);
              const valueText = cleanText(value?.text || "");
              if (!labelText) {
                return null;
              }

              rect.dataset.chartLabel = labelText;
              if (valueText) {
                rect.dataset.chartValue = valueText;
              }
              return rect;
            })
            .filter(Boolean);
        };

        const buildMapTooltip = (target) => {
          const country = cleanText(target.dataset.country);
          const explicitTitle = cleanText(target.dataset.tooltipTitle);
          const explicitBody = cleanText(target.dataset.tooltipBody);
          if (explicitTitle || explicitBody) {
            return {
              title: explicitTitle || country || copy.value,
              body: explicitBody
            };
          }
          if (!country) {
            return null;
          }
          const parts = [];
          const prevalence = cleanText(target.dataset.prevalence);
          const subregion = cleanText(target.dataset.subregion);
          const legal = cleanText(target.dataset.legal);
          const sexRatio = cleanText(target.dataset.sexRatio30);
          const share = cleanText(target.dataset.share);
          const births = cleanText(target.dataset.births);
          const year = cleanText(target.dataset.year);
          const duality = cleanText(target.dataset.duality).toLowerCase();

          if (share) {
            parts.push(`${copy.shareOfBirths}: ${share}%`);
          }
          if (births) {
            parts.push(`${copy.births2026}: ${births}`);
          }
          if (prevalence) {
            parts.push(`${copy.prevalence}: ${prevalence}%`);
          }
          if (subregion) {
            parts.push(`${copy.subregion}: ${subregion}`);
          }
          if (legal) {
            parts.push(`${copy.legal}: ${legal}`);
          }
          if (sexRatio) {
            const yearChunk = year ? ` (${year})` : "";
            parts.push(`${copy.sexRatio}${yearChunk}: ${sexRatio}`);
          }
          if (duality === "yes" || duality === "no") {
            parts.push(`${copy.duality}: ${duality === "yes" ? copy.yes : copy.no}`);
          }

          return {
            title: country,
            body: parts.join(" | ")
          };
        };

        const buildBarTooltip = (target) => {
          const explicitTitle = cleanText(target.dataset.tooltipTitle);
          const explicitBody = cleanText(target.dataset.tooltipBody);
          const label = cleanText(target.dataset.chartLabel);
          const value = cleanText(target.dataset.chartValue);

          if (explicitTitle || explicitBody) {
            return {
              title: explicitTitle || label || copy.value,
              body: explicitBody || (value ? `${copy.value}: ${value}` : "")
            };
          }

          if (!label) {
            return null;
          }
          return {
            title: label,
            body: value ? `${copy.value}: ${value}` : ""
          };
        };

        const setupChartTooltips = (figure) => {
          if (figure.dataset.disableChartTooltips === "true") {
            return;
          }
          const svg = figure.querySelector("svg");
          if (!svg) {
            return;
          }

          const mapTargets = Array.from(svg.querySelectorAll(".map-country[data-country]"));
          const barTargets = discoverBarTargets(svg);
          const explicitTargets = Array.from(
            svg.querySelectorAll("[data-tooltip-title], [data-tooltip-body]")
          );
          const targets = [...new Set([...mapTargets, ...barTargets, ...explicitTargets])];
          if (!targets.length) {
            return;
          }

          if (window.getComputedStyle(figure).position === "static") {
            figure.style.position = "relative";
          }

          const tooltip = document.createElement("div");
          tooltip.className = "entry-chart-tooltip";
          tooltip.hidden = true;

          const titleNode = document.createElement("p");
          titleNode.className = "entry-chart-tooltip__title";
          const bodyNode = document.createElement("p");
          bodyNode.className = "entry-chart-tooltip__body";

          tooltip.append(titleNode, bodyNode);
          figure.append(tooltip);

          let activeTarget = null;
          let pinnedTarget = null;

          const clearActive = () => {
            if (activeTarget) {
              activeTarget.classList.remove("is-active");
              activeTarget = null;
            }
          };

          const hideTooltip = () => {
            tooltip.hidden = true;
            clearActive();
          };

          const positionTooltip = (clientX, clientY) => {
            const bounds = figure.getBoundingClientRect();
            const tipBounds = tooltip.getBoundingClientRect();
            const inset = 8;
            const offset = 12;
            const left = clamp(clientX - bounds.left + offset, inset, bounds.width - tipBounds.width - inset);
            const top = clamp(clientY - bounds.top + offset, inset, bounds.height - tipBounds.height - inset);
            tooltip.style.left = `${left}px`;
            tooltip.style.top = `${top}px`;
          };

          const getTooltipPayload = (target) =>
            target.classList.contains("map-country") ? buildMapTooltip(target) : buildBarTooltip(target);

          const showTooltip = (target, sourceEvent) => {
            const payload = getTooltipPayload(target);
            if (!payload) {
              return;
            }
            titleNode.textContent = payload.title;
            bodyNode.textContent = payload.body;
            bodyNode.hidden = !payload.body;
            tooltip.hidden = false;

            if (activeTarget && activeTarget !== target) {
              activeTarget.classList.remove("is-active");
            }
            activeTarget = target;
            activeTarget.classList.add("is-active");

            if (sourceEvent && Number.isFinite(sourceEvent.clientX) && Number.isFinite(sourceEvent.clientY)) {
              positionTooltip(sourceEvent.clientX, sourceEvent.clientY);
              return;
            }

            const box = target.getBoundingClientRect();
            positionTooltip(box.left + box.width / 2, box.top + box.height / 2);
          };

          const onPointerLeave = () => {
            if (pinnedTarget) {
              return;
            }
            hideTooltip();
          };

          targets.forEach((target) => {
            target.classList.add("chart-tooltip-target");
            const isNativeFocusable = target instanceof HTMLElement;
            if (!target.hasAttribute("tabindex") && isNativeFocusable) {
              target.setAttribute("tabindex", "0");
            }
            const supportsKeyboardTooltip = target.hasAttribute("tabindex");

            const payload = getTooltipPayload(target);
            if (payload && !target.hasAttribute("aria-label")) {
              target.setAttribute("aria-label", payload.body ? `${payload.title}. ${payload.body}` : payload.title);
            }

            target.addEventListener("pointerenter", (event) => {
              if (pinnedTarget) {
                return;
              }
              showTooltip(target, event);
            });

            target.addEventListener("pointermove", (event) => {
              if (pinnedTarget || tooltip.hidden) {
                return;
              }
              positionTooltip(event.clientX, event.clientY);
            });

            target.addEventListener("pointerleave", onPointerLeave);

            if (supportsKeyboardTooltip) {
              target.addEventListener("focus", () => {
                showTooltip(target);
              });

              target.addEventListener("blur", () => {
                if (pinnedTarget) {
                  return;
                }
                hideTooltip();
              });
            }

            target.addEventListener("click", (event) => {
              if (pinnedTarget === target) {
                pinnedTarget = null;
                hideTooltip();
                return;
              }
              pinnedTarget = target;
              showTooltip(target, event);
              event.preventDefault();
            });
          });

          document.addEventListener("pointerdown", (event) => {
            if (!pinnedTarget) {
              return;
            }
            if (figure.contains(event.target)) {
              return;
            }
            pinnedTarget = null;
            hideTooltip();
          });

          figure.addEventListener("keydown", (event) => {
            if (event.key !== "Escape") {
              return;
            }
            pinnedTarget = null;
            hideTooltip();
          });
        };

        document.querySelectorAll(".entry-chart").forEach(setupChartTooltips);
      })();
    </script>
  </body>
</html>
