---
import { getCollection } from "astro:content";
import Layout from "../components/layout/Layout.astro";
import EntryCard from "../components/entry/EntryCard.astro";

const entries = (await getCollection("entries"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [
  { value: "All", label: "All" },
  { value: "Economics", label: "Economics" },
  { value: "Demographics", label: "Demographics" },
  { value: "Technology", label: "Technology" },
  { value: "Governance", label: "Governance" },
  { value: "Health", label: "Health" },
  { value: "Education", label: "Education" }
];
---

<Layout
  title="Archive"
  description="Full archive of Open Ordinal entries."
  lang="en"
  canonical="https://openordinal.org/archive"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>

  <section class="archive-shell">
    <h1 class="text-[46px] leading-tight text-ink">Archive</h1>
    <p class="mt-2 max-w-2xl text-[20px] text-dim">All entries. Filter by category.</p>

    {
      entries.length > 0 ? (
        <>
          <div class="no-print mt-8 border-b border-rule pb-4">
            <p class="ui-meta text-[10px] uppercase tracking-[0.14em] text-dim">Search Archive</p>
            <div id="archive-pagefind" class="mt-3"></div>
            <p id="archive-pagefind-hint" class="ui-meta mt-2 hidden text-[10px] text-dim">
              Search index is available after a production build.
            </p>
          </div>

          <div class="no-print mt-6 border-b border-rule pb-5">
            <p class="ui-meta text-[10px] uppercase tracking-[0.14em] text-dim">Category</p>
            <div class="archive-filter-row mt-3" role="toolbar" aria-label="Filter archive by category">
              {
                categories.map((category) => (
                  <button
                    type="button"
                    class="archive-filter-chip"
                    data-category-filter
                    data-category-value={category.value}
                    data-active={category.value === "All" ? "true" : undefined}
                    aria-pressed={category.value === "All" ? "true" : "false"}
                  >
                    {category.label}
                  </button>
                ))
              }
            </div>
          </div>

          <ul id="archive-list" class="mt-2">
            {
              entries.map((entry) => (
                <li
                  data-archive-card
                  data-category={entry.data.category}
                  data-search={`${entry.data.title} ${entry.data.scope}`.toLowerCase()}
                >
                  <EntryCard entry={entry} lang="en" />
                </li>
              ))
            }
          </ul>

          <div class="no-print mt-6 flex items-center justify-between pt-2">
            <button
              id="archive-prev"
              class="ui-meta border border-rule px-3 py-2 text-[10px] uppercase tracking-[0.15em] text-dim disabled:opacity-40"
              type="button"
            >
              Previous
            </button>
            <p id="archive-page" class="ui-meta text-[10px] uppercase tracking-[0.15em] text-dim">Page 1</p>
            <button
              id="archive-next"
              class="ui-meta border border-rule px-3 py-2 text-[10px] uppercase tracking-[0.15em] text-dim disabled:opacity-40"
              type="button"
            >
              Next
            </button>
          </div>
        </>
      ) : (
        <p class="mt-8 text-[20px] text-dim">No entries published yet.</p>
      )
    }
  </section>
</Layout>

<script>
  type PagefindUIConstructor = new (options: Record<string, unknown>) => unknown;
  const PAGEFIND_INPUT_ID = "archive-search-input";
  const PAGEFIND_INPUT_NAME = "archive-search";

  const ensureSearchFieldAttributes = (mount: HTMLElement) => {
    const applyAttributes = () => {
      const input = mount.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      if (!input) {
        return false;
      }

      input.id = PAGEFIND_INPUT_ID;
      input.name = PAGEFIND_INPUT_NAME;
      return true;
    };

    if (applyAttributes()) {
      return;
    }

    const observer = new MutationObserver(() => {
      if (applyAttributes()) {
        observer.disconnect();
      }
    });

    observer.observe(mount, { childList: true, subtree: true });
  };

  const initPagefind = () => {
    const mount = document.getElementById("archive-pagefind");
    const hint = document.getElementById("archive-pagefind-hint");

    if (!(mount instanceof HTMLElement)) {
      return;
    }

    const start = () => {
      const pagefindCtor = (window as Window & { PagefindUI?: unknown }).PagefindUI;

      if (typeof pagefindCtor !== "function") {
        return;
      }

      const PagefindUI = pagefindCtor as PagefindUIConstructor;

      new PagefindUI({
        element: "#archive-pagefind",
        resetStyles: false,
        showSubResults: true,
        pageSize: 8,
        excerptLength: 16,
        placeholder: "Search entries, scope, and source"
      });

      ensureSearchFieldAttributes(mount);
    };

    if ((window as Window & { PagefindUI?: unknown }).PagefindUI) {
      start();
      return;
    }

    const script = document.createElement("script");
    script.src = "/pagefind/pagefind-ui.js";
    script.async = true;
    script.addEventListener("load", start);
    script.addEventListener("error", () => {
      if (hint instanceof HTMLElement) {
        hint.classList.remove("hidden");
      }
    });
    document.body.appendChild(script);
  };

  initPagefind();

  const PAGE_SIZE = 20;
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-archive-card]"));
  const categoryButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-category-filter]")
  );
  const prevButton = document.getElementById("archive-prev");
  const nextButton = document.getElementById("archive-next");
  const pageText = document.getElementById("archive-page");
  const categoryValues = new Set(
    categoryButtons.map((button) => button.dataset.categoryValue).filter((value): value is string => Boolean(value))
  );

  let page = 1;
  let activeCategory = (() => {
    const requestedCategory = new URLSearchParams(window.location.search).get("category") || "";
    return categoryValues.has(requestedCategory) ? requestedCategory : "All";
  })();

  const syncCategoryButtons = () => {
    categoryButtons.forEach((button) => {
      const isActive = (button.dataset.categoryValue || "All") === activeCategory;
      button.toggleAttribute("data-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });
  };

  const getFilteredCards = () => {
    return cards.filter((card) => {
      const cardCategory = card.getAttribute("data-category") || "";
      const categoryMatch = activeCategory === "All" || cardCategory === activeCategory;
      return categoryMatch;
    });
  };

  const render = () => {
    const filtered = getFilteredCards();
    const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));

    if (page > totalPages) {
      page = totalPages;
    }

    cards.forEach((card) => {
      card.style.display = "none";
    });

    const start = (page - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;

    filtered.slice(start, end).forEach((card) => {
      card.style.display = "block";
    });

    if (pageText) {
      pageText.textContent = `Page ${page} of ${totalPages}`;
    }

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.disabled = page <= 1;
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.disabled = page >= totalPages;
    }
  };

  if (categoryButtons.length) {
    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextCategory = button.dataset.categoryValue || "All";
        if (nextCategory === activeCategory) {
          return;
        }
        activeCategory = nextCategory;
        page = 1;
        syncCategoryButtons();
        render();
      });
    });
  }

  if (prevButton) {
    prevButton.addEventListener("click", () => {
      page -= 1;
      render();
    });
  }

  if (nextButton) {
    nextButton.addEventListener("click", () => {
      page += 1;
      render();
    });
  }

  syncCategoryButtons();
  render();
</script>
