---
import Layout from "../components/layout/Layout.astro";
---

<Layout
  title="Not Found"
  description="This entry does not exist."
  lang="en"
  canonical="https://openordinal.org/404"
  robots="noindex, follow"
>
  <section class="archive-shell">
    <p class="text-[30px] text-ink">This entry doesn't exist - or not yet.</p>
    <p class="ui-meta mt-4 text-[11px] uppercase tracking-[0.14em] text-dim">
      <a href="/archive">Back to archive</a>
    </p>
  </section>
</Layout>
