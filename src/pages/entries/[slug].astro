---
import { getCollection } from "astro:content";
import Layout from "../../components/layout/Layout.astro";
import EntryHeader from "../../components/entry/EntryHeader.astro";
import HeroVisual from "../../components/entry/HeroVisual.astro";
import StatBlock from "../../components/entry/StatBlock.astro";
import ChartBlock from "../../components/entry/ChartBlock.astro";
import LimitationsList from "../../components/entry/LimitationsList.astro";
import SourcesList from "../../components/entry/SourcesList.astro";

export async function getStaticPaths() {
  const entries = (await getCollection("entries")).filter((entry) => !entry.data.draft);

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allEntries = (await getCollection("entries")).filter((item) => !item.data.draft);
const correction = allEntries.find((item) => item.data.correction_of === entry.slug);

const description = entry.data.description || `${entry.data.category} analysis for ${entry.data.scope}.`;
const canonical = `https://openordinal.org/entries/${entry.slug}`;
const ogImage = `https://openordinal.org/og/${entry.slug}.png`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  datePublished: entry.data.date.toISOString(),
  inLanguage: "en",
  author: {
    "@type": "Organization",
    name: "Open Ordinal"
  },
  publisher: {
    "@type": "Organization",
    name: "Open Ordinal"
  },
  mainEntityOfPage: canonical
};
---

<Layout
  title={entry.data.title}
  description={description}
  lang="en"
  type="article"
  canonical={canonical}
  ogImage={ogImage}
  structuredData={structuredData}
>
  <article class="archive-shell entry-prose">
    <EntryHeader entry={entry} lang="en" />

    {
      correction && (
        <p class="ui-meta mt-5 border border-rule p-3 text-[11px] text-dim">
          A correction entry is available: <a href={`/entries/${correction.slug}`}>{correction.data.title}</a>
        </p>
      )
    }

    <div class="mt-8">
      <Content components={{ HeroVisual, StatBlock, ChartBlock, LimitationsList, SourcesList }} />
    </div>
  </article>
</Layout>
