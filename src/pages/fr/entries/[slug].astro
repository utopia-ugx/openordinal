---
import { getCollection } from "astro:content";
import Layout from "../../../components/layout/Layout.astro";
import EntryHeader from "../../../components/entry/EntryHeader.astro";
import HeroVisual from "../../../components/entry/HeroVisual.astro";
import StatBlock from "../../../components/entry/StatBlock.astro";
import ChartBlock from "../../../components/entry/ChartBlock.astro";
import ScrollStory from "../../../components/entry/ScrollStory.astro";
import BarChart from "../../../components/entry/charts/BarChart.astro";
import LimitationsList from "../../../components/entry/LimitationsList.astro";
import SourcesList from "../../../components/entry/SourcesList.astro";
import SeeAlso from "../../../components/entry/SeeAlso.astro";
import TranslationNotice from "../../../components/ui/TranslationNotice.astro";
import { getRelatedEntries } from "../../../utils/relatedEntries";

export async function getStaticPaths() {
  const [entriesEn, entriesFr] = await Promise.all([
    getCollection("entries"),
    getCollection("entries-fr")
  ]);

  const slugs = new Set([
    ...entriesEn.filter((entry) => !entry.data.draft).map((entry) => entry.slug),
    ...entriesFr.filter((entry) => !entry.data.draft).map((entry) => entry.slug)
  ]);

  return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug ?? "";

const [entriesEn, entriesFr] = await Promise.all([
  getCollection("entries"),
  getCollection("entries-fr")
]);

const entriesEnPublished = entriesEn.filter((entry) => !entry.data.draft);
const entriesFrPublished = entriesFr.filter((entry) => !entry.data.draft);

const frEntry = entriesFrPublished.find((entry) => entry.slug === slug);
const enEntry = entriesEnPublished.find((entry) => entry.slug === slug);
const entry = frEntry ?? enEntry;

if (!entry) {
  throw new Error(`Entry not found for slug: ${slug}`);
}

const { Content } = await entry.render();
const isFallback = !frEntry && Boolean(enEntry);

const frBySlug = new Map(entriesFrPublished.map((entry) => [entry.slug, entry]));
const enBySlug = new Map(entriesEnPublished.map((entry) => [entry.slug, entry]));
const relatedPool = Array.from(new Set([...frBySlug.keys(), ...enBySlug.keys()]))
  .map((candidateSlug) => frBySlug.get(candidateSlug) ?? enBySlug.get(candidateSlug))
  .filter((candidate): candidate is NonNullable<typeof candidate> => Boolean(candidate));
const relatedEntries = getRelatedEntries(entry, relatedPool, { limit: 3 });

const title = frEntry
  ? frEntry.data.title_fr || frEntry.data.title
  : enEntry?.data.title || "Open Ordinal";

const description =
  (frEntry?.data.description || enEntry?.data.description) ||
  `Analyse de ${entry.data.category} pour ${entry.data.scope_fr || entry.data.scope}.`;

const canonical = `https://openordinal.org/fr/entries/${slug}`;
const ogImage = `https://openordinal.org/og/${slug}.png`;
const organizationId = "https://openordinal.org/#organization";

const structuredData = {
  "@type": "Article",
  "@id": `${canonical}#article`,
  headline: title,
  description,
  image: [ogImage],
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  inLanguage: isFallback ? "en" : "fr",
  articleSection: entry.data.category,
  isAccessibleForFree: true,
  author: {
    "@id": organizationId
  },
  publisher: {
    "@id": organizationId
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical
  }
};
---

<Layout
  title={title}
  description={description}
  lang="fr"
  type="article"
  canonical={canonical}
  ogImage={ogImage}
  structuredData={structuredData}
>
  {isFallback && <TranslationNotice />}

  <article class="archive-shell entry-prose" data-pagefind-body>
    <EntryHeader entry={entry} lang="fr" />

    <div class="mt-8">
      <Content
        components={{
          HeroVisual,
          StatBlock,
          ChartBlock,
          ScrollStory,
          BarChart,
          LimitationsList,
          SourcesList
        }}
      />
    </div>

    <SeeAlso items={relatedEntries} lang="fr" />
  </article>
</Layout>
