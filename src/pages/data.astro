---
import Layout from "../components/layout/Layout.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("entries"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => {
    const aNum = Number.parseInt(a.data.entry_number, 10);
    const bNum = Number.parseInt(b.data.entry_number, 10);
    if (Number.isFinite(aNum) && Number.isFinite(bNum) && aNum !== bNum) {
      return aNum - bNum;
    }
    return a.data.date.getTime() - b.data.date.getTime();
  });

const dataFiles = Object.keys(import.meta.glob("/src/content/data/*.{csv,json}"))
  .map((path) => path.split("/").pop())
  .filter((name): name is string => Boolean(name));

const toFormatLabel = (csvCount: number, jsonCount: number): string => {
  const parts: string[] = [];
  if (csvCount > 0) {
    parts.push("CSV");
  }
  if (jsonCount > 0) {
    parts.push("JSON");
  }

  const total = csvCount + jsonCount;
  const base = (csvCount > 0 ? 1 : 0) + (jsonCount > 0 ? 1 : 0);
  const subsets = total - base;

  if (subsets > 0) {
    return `${parts.join(", ")} + ${subsets} subsets`;
  }

  return parts.join(", ");
};

const dataRows = entries
  .map((entry) => {
    const files = dataFiles.filter(
      (file) =>
        file === `${entry.slug}.csv` ||
        file === `${entry.slug}.json` ||
        file.startsWith(`${entry.slug}-`)
    );

    const csvCount = files.filter((file) => file.endsWith(".csv")).length;
    const jsonCount = files.filter((file) => file.endsWith(".json")).length;

    if (csvCount + jsonCount === 0) {
      return null;
    }

    return {
      slug: entry.slug,
      title: entry.data.title,
      formats: toFormatLabel(csvCount, jsonCount)
    };
  })
  .filter((row): row is { slug: string; title: string; formats: string } => Boolean(row));
---

<Layout
  title="Data"
  description="Downloadable datasets for Open Ordinal entries."
  lang="en"
  canonical="https://openordinal.org/data"
>
  <section class="archive-shell entry-prose">
    <h1 class="text-[46px] leading-tight text-ink">Data</h1>

    <p class="mt-6 max-w-4xl">
      Structured datasets on this page are derived from publicly available sources. Source attribution and original terms are documented in each entry.
    </p>
    <p class="max-w-4xl">
      Users should consult original source licenses before redistribution. Structured versions are released under CC BY 4.0, while upstream source licenses still apply.
    </p>

    <p class="ui-meta mt-8 text-[12px] text-dim">
      Open data folder:
      <a href="https://github.com/openordinal/open-ordinal/tree/main/src/content/data" target="_blank" rel="noreferrer">View on GitHub ↗</a>
    </p>

    <div class="mt-4 overflow-x-auto">
      <table>
        <thead>
          <tr>
            <th>Entry</th>
            <th>Formats</th>
          </tr>
        </thead>
        <tbody>
          {
            dataRows.map((row) => (
              <tr>
                <td>{row.title}</td>
                <td>{row.formats}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</Layout>
